# ── Límites de almacenamiento por servidor ────────────────────────────────────
# A diferencia de .env, este archivo NO contiene secretos y SÍ se versiona en
# git (no está en .gitignore). Para ajustar un límite: editar, commitear, y en
# el servidor `git pull` + reiniciar el bot — sin tocar el .env manualmente.

# Máximo de mensajes en corpus_messages POR CANAL (se purgan los más viejos de
# ese canal). No es un tope de guild: cada canal tiene su propia cuota, así un
# canal con mucho historial no desplaza el corpus de los demás canales.
MAX_CORPUS_MESSAGES_PER_GUILD_FREE=15000
MAX_CORPUS_MESSAGES_PER_GUILD_PREMIUM=50000

# Máximo de mensajes en user_corpus por guild (total de todos los autores combinados).
MAX_USER_CORPUS_MESSAGES_PER_GUILD_FREE=5000
MAX_USER_CORPUS_MESSAGES_PER_GUILD_PREMIUM=20000

# Máximo de GIFs por guild. Al llegar al límite se descarta el más viejo (y se borra de R2 si aplica).
MAX_GIFS_PER_GUILD_FREE=1500
MAX_GIFS_PER_GUILD_PREMIUM=4000

# Tamaño máximo de un GIF para subirlo a R2 (en bytes). Default: 8 MB.
# Si el GIF supera este tamaño no se sube a R2 NI se guarda en corpus_gifs.
MAX_GIF_DOWNLOAD_BYTES=8388608

# Máximo de imágenes en el pool de memes por guild.
MAX_IMAGES_PER_GUILD_FREE=75
MAX_IMAGES_PER_GUILD_PREMIUM=200

# Máximo de anuncios programados por guild (suma de ambos modos, intervalo + hora fija).
# Al llegar al límite, add_scheduled_announcement rechaza el alta (no se evictan anuncios viejos).
MAX_ANNOUNCEMENTS_PER_GUILD_FREE=3
MAX_ANNOUNCEMENTS_PER_GUILD_PREMIUM=10
