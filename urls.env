# ── URLs y dominios públicos ───────────────────────────────────────────────────
# A diferencia de .env, este archivo NO contiene secretos y SÍ se versiona en
# git (no está en .gitignore). Para cambiar un dominio (ej: una migración
# como panel.purg4t0ry.com → panel.purgito.app): editar, commitear, y en
# el servidor `git pull` + reiniciar el bot — sin tocar el .env manualmente.

# URL pública del dashboard web. Se muestra en /help, /setup y /settings
# para que los admins descubran el panel, y es la base de los links del panel.
PANEL_URL=https://panel.purgito.app

# Host público donde corre el dashboard (OAuth2 de Discord + sesión). Se usa
# para armar el redirect_uri exacto: {DASHBOARD_BASE_URL}/auth/callback.
DASHBOARD_BASE_URL=https://panel.purgito.app

# URL pública de la landing. Destino del redirect post-login cuando el
# usuario inició sesión desde la landing (/auth/login?from=landing).
LANDING_URL=https://purgito.app

# Orígenes de la landing pública que pueden hacer requests autenticadas
# (con cookies) al dashboard, separados por coma.
LANDING_ORIGINS=https://purgito.app,https://www.purgito.app

# Dominio para compartir la cookie de sesión entre subdominios (landing +
# panel). En producción: .purgito.app — dejar vacío en desarrollo local
# (cookie atada solo al host que la emite, comportamiento clásico).
SESSION_COOKIE_DOMAIN=.purgito.app
