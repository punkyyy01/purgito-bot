# Copia este archivo a .env y pon tus credenciales
# NO coloques tokens reales aquí; usa .env (este archivo es público)
#
# Variables OBLIGATORIAS: DISCORD_TOKEN
# Variables OPCIONALES: todo lo demás tiene valores por defecto o fallback

# ── Obligatorio ──────────────────────────────────────────────────────────────

# Token del bot de Discord
DISCORD_TOKEN=tu-token-de-bot-aqui

# ── Intents ───────────────────────────────────────────────────────────────────

# Habilitar lectura de contenido de mensajes (requiere habilitarlo en el Developer Portal)
ENABLE_MESSAGE_CONTENT=true

# ── Desarrollo ────────────────────────────────────────────────────────────────

# ID del servidor para sync instantáneo de slash commands (opcional)
# Sin esto, los comandos tardan hasta 1 hora en propagarse globalmente
GUILD_ID=tu-id-de-servidor

# ── Comportamiento del bot ────────────────────────────────────────────────────

# Nombre con el que se activa el trigger de memes por texto (ej: "artemis generar")
# Fallback: artemis
BOT_TRIGGER_NAME=purgito

# [DEPRECADA] ID del servidor home original. Se lee UNA sola vez al arrancar para migrar
# el guild a la tabla premium_guilds. Después de la primera ejecución ya no tiene efecto.
# Reemplazada por el sistema premium (/premium add|quitar|lista).
HOME_GUILD_ID=

# ID de Discord del dueño del bot. Necesario para usar los comandos /premium.
# Ejemplo: BOT_OWNER_ID=123456789012345678
BOT_OWNER_ID=

# ── Opcional — IA para captions de memes ─────────────────────────────────────

# Groq API Key — para captions de memes con IA (fallback a Markov si no está)
GROQ_API_KEY=tu-groq-api-key

# ── Límites de importación de historial (corpus) ─────────────────────────────

# /refeed: máximo de mensajes a leer del canal actual
REFEED_MAX_MESSAGES=80000
# /refeed_all: máximo de mensajes a leer por canal
REFEED_ALL_MAX_MESSAGES=20000

# ── Markov (muestra de entrenamiento) ─────────────────────────────────────────

# Evita cargar todo el corpus a RAM. Se entrena con un muestreo aleatorio.
MARKOV_TRAINING_MESSAGES=5000
USER_MARKOV_TRAINING_MESSAGES=2000

# ── Límites de almacenamiento por servidor ────────────────────────────────────

# Máximo de mensajes en corpus_messages por guild (se purgan los más viejos).
MAX_CORPUS_MESSAGES_PER_GUILD=50000
# Máximo de mensajes en user_corpus por guild (total de todos los autores combinados).
MAX_USER_CORPUS_MESSAGES_PER_GUILD=20000
# Máximo de GIFs por guild. Al llegar al límite se descarta el más viejo (y se borra de R2 si aplica).
MAX_GIFS_PER_GUILD=300
# Tamaño máximo de un GIF para subirlo a R2 (en bytes). Default: 8 MB.
# Si el GIF supera este tamaño no se sube a R2 NI se guarda en corpus_gifs.
MAX_GIF_DOWNLOAD_BYTES=8388608
# Máximo de imágenes en el pool de memes por guild.
MAX_IMAGES_PER_GUILD=200

# ── Limpieza de datos al salir de un servidor ─────────────────────────────────

# Días de gracia antes de purgar todos los datos de un server del que el bot fue expulsado.
# Durante este período, si el bot es reinvitado los datos se conservan.
GUILD_DATA_RETENTION_DAYS=30

# ── Opcional — almacenamiento de GIFs e imágenes (Cloudflare R2) ─────────────
# Si no se configuran, las URLs de Discord CDN se guardan tal cual
# (pueden expirar cuando Discord elimine el adjunto original).
# Todas las variables deben estar presentes para que R2 se active.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── Web API (gestión de GIFs via HTTP) ───────────────────────────────────────
# Puerto donde escucha la API REST pública. Se inicia junto con el bot.
WEB_PORT=8080

# ── Opcional — cookies de YouTube para yt-dlp ────────────────────────────────
# Ruta al archivo cookies.txt exportado de tu sesión de YouTube.
# Necesario solo si YouTube bloquea descargas (bot detection).
# En producción el default es /opt/bot-discord-purg/cookies.txt
# Para generar el archivo: usá la extensión "Get cookies.txt LOCALLY" en Chrome/Firefox,
# exportá desde youtube.com y copiá el resultado a esta ruta.
# Si la variable está vacía y el archivo default no existe, yt-dlp funciona sin cookies
# (puede fallar con videos con restricciones o si YouTube detecta el bot).
YTDLP_COOKIES=/opt/bot-discord-purg/cookies.txt
